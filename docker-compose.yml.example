services:
  postgres:
    image: postgres:16
    container_name: todo-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: tododb
      POSTGRES_USER: your_db_user
      POSTGRES_PASSWORD: your_secure_password
    volumes:
      - pgdata:/var/lib/postgresql/data
  backend:
    image: todo-backend
    container_name: todo-backend
    restart: unless-stopped
    environment:
      - DATABASE_URL=postgresql://your_db_user:your_secure_password@postgres:5432/tododb
    depends_on:
      - postgres
  frontend:
    image: todo-frontend
    container_name: todo-frontend
    restart: unless-stopped
    ports:
      - "80:80"
    depends_on:
      - backend
volumes:
  pgdata:
